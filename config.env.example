# =============================================================================
# fact-diagonal — archivo de configuración de ejemplo.
#
# Copiar a `config.env` y completar con los valores reales del entorno:
#     cp config.env.example config.env
#
# `config.env` está en .gitignore (contiene secretos) y NO debe subirse.
# Este archivo (config.env.example) SÍ se versiona como referencia de despliegue.
# =============================================================================

# --- Módulo 1 — Microsoft Graph (OAuth2 Client Credentials) -----------------

# ID del tenant de Azure AD (Directory ID).
TENANT_ID=

# ID de la aplicación registrada en Azure AD (App registration / Client ID).
CLIENT_ID=

# Secreto del cliente de la aplicación registrada.
CLIENT_SECRET=

# Buzón a procesar, p.ej. facturae@empresa.com.co
MAILBOX=

# Opcional. Carpeta de entrada de la que leer los correos, por su nombre visible
# (p.ej. Pruebas). Si se deja vacía se lee de la Bandeja de entrada (Inbox), que
# es el comportamiento normal.
#
# La carpeta indicada pasa a ser la RAÍZ del flujo: los correos se leen de ella y
# /Procesados y /Pendientes se crean COLGANDO DE ELLA (p.ej. Pruebas/Procesados),
# no bajo la Bandeja de entrada. Así una corrida de pruebas queda contenida y no
# toca el árbol real de Inbox.
#
# Se busca primero entre las carpetas de primer nivel del buzón (hermanas de la
# Bandeja de entrada) y luego entre las subcarpetas de la Bandeja de entrada. La
# carpeta debe existir: el agente NO la crea y se detiene si no la encuentra, para
# no procesar la Bandeja de entrada real por un nombre mal escrito.
INBOX_FOLDER=

# Destinatario de las notificaciones de error críticas (Mejora 1), p.ej.
# soporte@empresa.com.co. El remitente es el buzón MAILBOX. Si se deja vacío, las
# notificaciones solo se registran en el log local (no se envía correo).
SMTP_TO=soporte@diagonal.com.co

# Modo simulación. true = solo lectura: nunca mueve/marca correos ni escribe en
# la BD (los UPDATE/INSERT solo se registran en el log). Poner false para operar
# de verdad. Valores aceptados: true/false, 1/0, si/no, on/off. Por defecto true.
SIMULATION_MODE=true

# Máximo de correos a procesar por corrida (límite de seguridad). Por defecto 5
# si se deja vacío o con un valor no numérico/<=0.
MAX_CORREOS=5

# Opcional. Si se define, solo se procesan los correos cuyo remitente contenga
# esta subcadena (case-insensitive). Útil para pruebas dirigidas a un proveedor.
# Dejar vacío para procesar todos los remitentes.
FILTER_FROM=

# --- Licenciamiento (Nivel 1 + Nivel 2) -------------------------------------
# El agente valida la licencia como primer paso, antes de cualquier otra
# operación. Si la validación falla, se detiene sin revelar la causa. La semilla
# secreta del HMAC NO vive aquí: está compilada en el binario.

# ALLOWED_HOST — OBSOLETO. Se ignora por completo en la validación de licencia y
# ya no participa en el cálculo del HMAC. Puede dejarse por compatibilidad.
ALLOWED_HOST=DIAGAPP01

# Nombre del cliente al que se licencia. Es la única entrada del cálculo
# HMAC-SHA256 de LICENSE_KEY.
CLIENT_NAME=DIAGONAL

# Clave de licencia. La emite Acceso Seguro con la función
# license.Generate(CLIENT_NAME). Dejar vacía deja el agente sin licencia válida
# (no arrancará).
LICENSE_KEY=

# --- Módulo 2 — extracción de datos de adjuntos -----------------------------

# Clave de Gemini API usada como último eslabón de la cascada de extracción
# (texto nativo → Tesseract → Gemini). Dejar vacía deshabilita ese eslabón.
GEMINI_API_KEY=

# Modelo de Gemini a usar. Configurable porque Google depreca modelos con el
# tiempo (un modelo retirado devuelve 404). Por defecto gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# Región/location de Gemini. Por defecto global.
GEMINI_LOCATION=global

# --- Módulo 3 — integración con SQL Server ----------------------------------
# Si DB_SERVER (o DB_USER/DB_NAME_DMS/DB_NAME_ADJ) está vacío, el Módulo 3 se
# omite y el agente solo hace la extracción del Módulo 2.

# Host del servidor SQL Server (p.ej. localhost).
DB_SERVER=

# Puerto del servidor SQL Server (por defecto 1433).
DB_PORT=1433

# Usuario de SQL Server.
DB_USER=

# Contraseña de SQL Server.
DB_PASSWORD=

# Base de datos que contiene Man_RadicadoFacturas_Test (p.ej. DMSDiagonal).
DB_NAME_DMS=

# Base de datos que contiene la tabla Adjuntos.
DB_NAME_ADJ=

# Stored Procedure que resuelve el Módulo 3 (buscar/actualizar/insertar).
# Por defecto Spd_IA_DocumentosElectronicos si se deja vacío. En pruebas locales
# puede apuntarse a un SP alterno (p.ej. Spd_IA_Test).
SP_NAME=Spd_IA_DocumentosElectronicos
