# =============================================================================
# fact-diagonal — archivo de configuración de ejemplo.
#
# Copiar a `config.env` y completar con los valores reales del entorno:
#     cp config.env.example config.env
#
# `config.env` está en .gitignore (contiene secretos) y NO debe subirse.
# Este archivo (config.env.example) SÍ se versiona como referencia de despliegue.
# =============================================================================

# --- Módulo 1 — Microsoft Graph (OAuth2 Client Credentials) -----------------

# ID del tenant de Azure AD (Directory ID).
TENANT_ID=

# ID de la aplicación registrada en Azure AD (App registration / Client ID).
CLIENT_ID=

# Secreto del cliente de la aplicación registrada.
CLIENT_SECRET=

# Buzón a procesar, p.ej. facturae@empresa.com.co
MAILBOX=

# Modo simulación. true = solo lectura: nunca mueve/marca correos ni escribe en
# la BD (los UPDATE/INSERT solo se registran en el log). Poner false para operar
# de verdad. Valores aceptados: true/false, 1/0, si/no, on/off. Por defecto true.
SIMULATION_MODE=true

# Máximo de correos a procesar por corrida (límite de seguridad). Por defecto 5
# si se deja vacío o con un valor no numérico/<=0.
MAX_CORREOS=5

# Opcional. Si se define, solo se procesan los correos cuyo remitente contenga
# esta subcadena (case-insensitive). Útil para pruebas dirigidas a un proveedor.
# Dejar vacío para procesar todos los remitentes.
FILTER_FROM=

# --- Módulo 2 — extracción de datos de adjuntos -----------------------------

# Clave de Gemini API usada como último eslabón de la cascada de extracción
# (texto nativo → Tesseract → Gemini). Dejar vacía deshabilita ese eslabón.
GEMINI_API_KEY=

# --- Módulo 3 — integración con SQL Server ----------------------------------
# Si DB_SERVER (o DB_USER/DB_NAME_DMS/DB_NAME_ADJ) está vacío, el Módulo 3 se
# omite y el agente solo hace la extracción del Módulo 2.

# Host del servidor SQL Server (p.ej. localhost).
DB_SERVER=

# Puerto del servidor SQL Server (por defecto 1433).
DB_PORT=1433

# Usuario de SQL Server.
DB_USER=

# Contraseña de SQL Server.
DB_PASSWORD=

# Base de datos que contiene Man_RadicadoFacturas_Test (p.ej. DMSDiagonal).
DB_NAME_DMS=

# Base de datos que contiene la tabla Adjuntos.
DB_NAME_ADJ=
